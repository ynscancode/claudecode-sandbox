# Turso (libSQL) database connection — REQUIRED, no local-file fallback.
# The server will not start without both of these set.
# For LOCAL dev with no cloud DB, use a file: URL instead of a real Turso database —
# TURSO_DATABASE_URL=file:./budget.db works with no auth token required (file: URLs
# don't need one); this is how QA smoke-tested the no-cloud path.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Simple bearer-token auth. Set to any long random string in production to
# protect the API. Leave unset for local dev (gate is skipped when not set).
# Generate one with: openssl rand -hex 32
API_TOKEN=

# Ollama Cloud config for the optional "Suggest with AI" import feature.
# The feature is hard-disabled (no external call) unless OLLAMA_CLOUD_API_KEY is set.
# This file is a template — copy to server/.env (gitignored) and fill in a real key.
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=gpt-oss:20b-cloud
OLLAMA_CLOUD_BASE_URL=https://ollama.com
